generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Migrations cannot run through the transaction-mode pooler (6543); they need
  // the session-mode pooler (5432).
  directUrl = env("DIRECT_URL")
}

model User {
  id                String     @id @default(cuid())
  email             String     @unique
  passwordHash      String
  name              String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  portfolio         Portfolio?
  wishlist          Wishlist?
  portfolioInsights PortfolioInsight[]
  scoringPreferences UserScoringPreferences?

  @@index([email])
}

model Portfolio {
  id           String        @id @default(cuid())
  userId       String        @unique
  baseCurrency String        @default("EUR")
  totalValue   Decimal       @default(0) @db.Decimal(20, 2)
  totalCost    Decimal       @default(0) @db.Decimal(20, 2)
  realizedPL   Decimal       @default(0) @db.Decimal(20, 2)
  unrealizedPL Decimal       @default(0) @db.Decimal(20, 2)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  positions    Position[]
  transactions Transaction[]

  @@index([userId])
}

model Position {
  id                  String        @id @default(cuid())
  portfolioId         String
  ticker              String
  name                String
  exchange            String
  currency            String        @default("EUR")
  quantity            Decimal       @db.Decimal(20, 8)
  avgCostBasis        Decimal       @db.Decimal(20, 2)
  currentPrice        Decimal       @db.Decimal(20, 2)
  marketValue         Decimal       @db.Decimal(20, 2)
  unrealizedPL        Decimal       @db.Decimal(20, 2)
  unrealizedPLPercent Decimal       @db.Decimal(10, 2)
  firstBuyDate        DateTime
  lastActivity        DateTime
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  portfolio           Portfolio     @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  transactions        Transaction[]

  @@unique([portfolioId, ticker])
  @@index([portfolioId])
  @@index([ticker])
}

model Transaction {
  id          String          @id @default(cuid())
  portfolioId String
  positionId  String?
  type        TransactionType
  ticker      String
  name        String
  quantity    Decimal         @db.Decimal(20, 8)
  price       Decimal         @db.Decimal(20, 2)
  totalAmount Decimal         @db.Decimal(20, 2)
  fees        Decimal         @default(0) @db.Decimal(20, 2)
  executedAt  DateTime
  createdAt   DateTime        @default(now())
  portfolio   Portfolio       @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  position    Position?       @relation(fields: [positionId], references: [id])
  notes       String?

  @@index([portfolioId])
  @@index([ticker])
  @@index([executedAt])
  @@index([positionId, executedAt])
}

model Wishlist {
  id        String         @id @default(cuid())
  userId    String         @unique
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     WishlistItem[]
}

model WishlistItem {
  id           String   @id @default(cuid())
  wishlistId   String
  ticker       String
  name         String
  currency     String   @default("EUR")
  addedPrice   Decimal  @db.Decimal(20, 2)
  currentPrice Decimal  @db.Decimal(20, 2)
  targetPrice  Decimal? @db.Decimal(20, 2)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  wishlist     Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)

  @@unique([wishlistId, ticker])
}

model FundamentalData {
  id               String   @id @default(cuid())
  symbol           String   @unique
  lastUpdated      DateTime @default(now())
  marketCap        Float?
  enterpriseValue  Float?
  peRatio          Float?
  forwardPE        Float?
  pegRatio         Float?
  psRatio          Float?
  pbRatio          Float?
  pfcfRatio        Float?
  evToEbitda       Float?
  evToRevenue      Float?
  profitMargin     Float?
  operatingMargin  Float?
  netMargin        Float?
  roe              Float?
  roa              Float?
  roic             Float?
  revenueGrowth    Float?
  earningsGrowth   Float?
  ebitdaGrowth     Float?
  fcfGrowth        Float?
  currentRatio     Float?
  quickRatio       Float?
  debtToEquity     Float?
  debtToAssets     Float?
  interestCoverage Float?
  dividendYield    Float?
  payoutRatio      Float?
  dividendGrowth   Float?
  eps              Float?
  forwardEps       Float?
  bookValue        Float?
  fcfPerShare      Float?
  revenue          Float?
  incomeStatement  Json?
  balanceSheet     Json?
  cashFlow         Json?
  fundamentalScore Float?
  scoreDetails     Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([symbol])
  @@index([lastUpdated])
}

model AnalystRating {
  id                 String    @id @default(cuid())
  symbol             String    @unique
  targetPrice        Decimal?  @db.Decimal(10, 2)
  targetLowPrice     Decimal?  @db.Decimal(10, 2)
  targetHighPrice    Decimal?  @db.Decimal(10, 2)
  strongBuy          Int       @default(0)
  buy                Int       @default(0)
  hold               Int       @default(0)
  sell               Int       @default(0)
  strongSell         Int       @default(0)
  totalAnalysts      Int       @default(0)
  averageRating      Decimal?  @db.Decimal(3, 2)
  score              Float     @default(5.0)
  scoreInterpretation String   @default("No analyst data available")
  revisions          Json?
  lastUpdated        DateTime  @default(now())
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([symbol])
}

model IndustryComparison {
  id               String   @id @default(cuid())
  symbol           String   @unique
  industry         String
  sector           String
  avgPeRatio       Float?
  avgPbRatio       Float?
  avgPsRatio       Float?
  avgRoe           Float?
  avgProfitMargin  Float?
  avgDebtToEquity  Float?
  avgDividendYield Float?
  pePercentile     Float?
  growthPercentile Float?
  profitPercentile Float?
  healthPercentile Float?
  lastUpdated      DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([industry])
  @@index([sector])
}

enum TransactionType {
  BUY
  SELL
}

model NewsArticle {
  id              String    @id @default(cuid())
  title           String
  summary         String?   @db.Text
  content         String?   @db.Text
  url             String    @unique
  source          String
  author          String?
  publishedAt     DateTime
  imageUrl        String?
  
  // Sentiment Analysis
  sentiment       Float?    // -1 to 1 scale
  sentimentLabel  String?   // negative, neutral, positive
  confidence      Float?    // 0 to 1 confidence score
  
  // Relevance
  symbols         String[]  // Related stock symbols
  topics          String[]  // Topics/categories
  relevanceScore  Float?    // 0 to 1 relevance
  
  // AI Analysis
  aiSummary       String?   @db.Text
  keyPoints       Json?     // Bullet points of key information
  impact          String?   // low, medium, high
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([publishedAt])
  @@index([symbols])
  @@index([sentiment])
}

model PortfolioInsight {
  id              String    @id @default(cuid())
  userId          String
  date            DateTime  @db.Date
  
  // Overall Market
  marketSummary   String    @db.Text
  marketSentiment Float
  
  // Portfolio Specific
  portfolioImpact String    @db.Text
  topRisks        Json      // Array of risk factors
  opportunities   Json      // Array of opportunities
  
  // Recommendations
  recommendations Json      // Array of actionable items
  
  createdAt       DateTime  @default(now())
  
  user            User      @relation(fields: [userId], references: [id])
  
  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

model SentimentHistory {
  id              String    @id @default(cuid())
  symbol          String
  date            DateTime
  
  // Daily aggregated sentiment
  avgSentiment    Float     // -1 to 1
  newsCount       Int       // Number of articles
  positiveCount   Int
  neutralCount    Int
  negativeCount   Int
  
  // Weighted by impact
  weightedSentiment Float?  // Weighted by article impact
  
  createdAt       DateTime  @default(now())
  
  @@unique([symbol, date])
  @@index([symbol])
  @@index([date])
}

// Per-user scoring weights (plans/2026-07-20-configurable-scoring-weights.md,
// ADR-20). Ten discrete nullable Float columns, not a Json blob — the set is
// fixed and known at schema-design time. Stored raw (exactly what the user
// typed); normalization to sum-to-1.0 happens at scoring/read time in
// lib/utils/scoring-weights.ts, never here. Null columns (or no row at all)
// coalesce to DEFAULT_SCORING_WEIGHTS in the preferences service, so a user
// who has never touched Settings scores byte-identically to today.
model UserScoringPreferences {
  id     String @id @default(cuid())
  userId String @unique

  // Composite category weights (raw, relative — normalised at scoring time)
  wCompositeIntrinsic   Float?
  wCompositeFundamental Float?
  wCompositeTechnical   Float?
  wCompositeSentiment   Float?
  wCompositeAnalyst     Float?

  // Fundamental subcategory weights (raw, relative)
  wFundValuation     Float?
  wFundProfitability Float?
  wFundGrowth        Float?
  wFundFinancial     Float?
  wFundDividend      Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
