# Database (Supabase PostgreSQL) — two different pooler modes, both required.
# DATABASE_URL: transaction-mode pooler (port 6543) — used by the app at runtime (Prisma Client).
DATABASE_URL="postgresql://user:password@host:6543/database?pgbouncer=true"
# DIRECT_URL: session-mode pooler (port 5432) — required by `prisma migrate`/`prisma db push`,
# which need a direct session (transaction-mode pooling doesn't support prepared statements).
DIRECT_URL="postgresql://user:password@host:5432/database"

# NextAuth
# NEXTAUTH_URL is only needed in production or non-standard setups
NEXTAUTH_URL="http://localhost:3000"
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="generate-a-secret-with-openssl"

# News API (get a free key from https://newsapi.org)
NEWS_API_KEY="your-newsapi-key"

# Google Gemini AI (get from https://aistudio.google.com/apikey)
GEMINI_API_KEY="your-gemini-api-key"
