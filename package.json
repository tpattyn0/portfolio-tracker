{
  "name": "portfolio-tracker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "secret-scan": "gitleaks detect --source . --no-git -c .gitleaks.toml --redact -i .gitleaks-local",
    "secret-scan:history": "gitleaks detect --source . --log-opts=--all -c .gitleaks.toml --redact -i /dev/null",
    "verify": "npm run typecheck && npm run lint && npm run test && npm run secret-scan",
    "verify:code": "npm run typecheck && npm run lint && npm run test",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate"
  },
